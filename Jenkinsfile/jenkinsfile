pipeline {

agent any

tools {

maven 'Maven3'

}

stages {

stage('Checkout') {

steps {

git 'https://github.com/user/cloud-cost-dashboard.git'

}

}

stage('Build') {

steps {

sh 'mvn clean package'

}

}

stage('SonarQube Analysis') {

steps {

sh '''
mvn sonar:sonar
'''
}

}

stage('Trivy Scan') {

steps {

sh 'trivy fs .'

}

}

stage('Deploy Artifact Nexus') {

steps {

sh 'mvn deploy'

}

}

stage('Docker Build') {

steps {

sh '''
docker build -t cloud-cost-dashboard:${BUILD_NUMBER} .
'''
}

}

stage('Docker Push') {

steps {

sh '''
docker push username/cloud-cost-dashboard:${BUILD_NUMBER}
'''
}

}

stage('Deploy Kubernetes') {

steps {

sh '''
kubectl apply -f k8s/
'''
}

}

}

}

